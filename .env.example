# .env.example — Copy to .env and set values
# Required: set a strong secret for production
MURMUR_JWT_SECRET=change-me-to-a-random-string

# Required: your server's LAN IP (for HTTPS cert + PWA install on phones)
MURMUR_HOST=192.168.0.29

# Optional: host ports (defaults: 443 for HTTPS, 80 for HTTP setup page)
MURMUR_PORT=443
MURMUR_HTTP_PORT=8080

# Optional: Hugging Face token (required for voice cloning)
# HF_TOKEN=hf_...
